REDIS_URL=redis://localhost:6379/0
REQUIRE_DATABASE=true
NEXT_PUBLIC_API_URL=http://localhost:8000

# Demo/test-only switches. Leave these off for the real resume project.
ALLOW_LOCAL_EMBEDDINGS=false
ALLOW_IN_MEMORY_CACHE=false
ALLOW_MEMORY_VECTOR_SEARCH=false
